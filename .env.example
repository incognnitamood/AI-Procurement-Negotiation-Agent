# HuggingFace Configuration (Required for LLM-based inference)
HF_TOKEN=your_huggingface_api_token_here

# LLM Configuration (Optional - defaults provided)
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Environment Server (Optional - defaults to localhost)
ENV_URL=http://localhost:8000

# ⚠️ SECURITY WARNING ⚠️
# - Never commit this file to version control
# - .gitignore is configured to prevent this
# - Copy this to .env and fill in your actual values
# - Get HF_TOKEN from: https://huggingface.co/settings/tokens
